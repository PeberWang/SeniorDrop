# ====== 配置说明 ======
# "需要你填的"：把等于号右边的示例值换成你自己的
# "一般不用动"：保持默认值即可
# "先留空"：跑完第一条命令后再回来填
# 等号两边不要加空格

# ====== 需要你填的 ======

# 飞书应用（飞书开放平台 → 你的应用 → 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek（platform.deepseek.com → API Keys）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 GLM（open.bigmodel.cn → API Keys）
GLM_API_KEY=xxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# 阿里云 OSS（阿里云控制台 → 对象存储 OSS → Bucket 列表 → 你的 bucket → 概览）
# bucket 名就是你在阿里云创建 bucket 时取的名字，纯小写字母
OSS_BUCKET=你的bucket名
# endpoint 是 bucket 所在地域的访问地址，用 https:// 开头
# 阿里云控制台显示的 endpoint 不带 https://，你自己加上
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
# AccessKey 是阿里云的账号密码（RAM 控制台 → 用户 → 你的子账号 → 创建 AccessKey）
OSS_ACCESS_KEY_ID=LTAIxxxxxxxxxxxxxxxx
OSS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 公共读直链——拼法固定：https://你的bucket名.你的endpoint去掉https://
# 举例：bucket 叫 ppe-giftbox，endpoint 是 oss-cn-beijing.aliyuncs.com
#       → 填 https://ppe-giftbox.oss-cn-beijing.aliyuncs.com
OSS_PUBLIC_BASE=https://你的bucket名.oss-cn-beijing.aliyuncs.com

# 知识库名称——在飞书知识库里显示的名字，自己定，可以带空格
WIKI_SPACE_NAME=PPE 实验班课程资料

# ====== 先留空 ======

# 多维表格的 ID——跑完 init-bitable 命令后把返回值填在这里
BITABLE_APP_TOKEN=

# ====== 一般不用动 ======

# 飞书（默认值就是标准飞书，企业版用户才需要改）
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_DOC_HOST=feishu.cn

# DeepSeek（默认值即可，用其他模型才需要改）
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# 智谱 GLM（默认值即可）
GLM_OCR_URL=https://open.bigmodel.cn/api/paas/v4/layout_parsing

# 资料存储方式——改为 aliyun_oss 才会存到阿里云（必须改）
CLOUD_DRIVE_BACKEND=aliyun_oss
# 摘要文件的本地缓存目录（保持默认）
SUMMARY_DIR=./data/summaries
# 本地资料目录（学生提交的资料暂存位置，保持默认）
MATERIALS_BASE=./data/courses

# OSS 认证方式——access_key 即可（个人用 AK/SK 密码对）
OSS_AUTH_MODE=access_key
# 预签名链接有效期（秒），86400 = 24 小时。设了公共读之后这个字段用不上，留默认值即可
OSS_PRESIGNED_TTL=86400

# 日志（默认即可）
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/app.log

# ====== 高级配置（看不懂就跳过，不影响使用） ======

# 以下字段仅在企业级部署时用到，个人使用全部留空
# RAM Role ARN（认证模式改为 ram_role 时才填）
OSS_ROLE_ARN=
# RAM 角色会话名（ram_role 模式时随便取个名字）
OSS_ROLE_SESSION_NAME=ppe-giftbox-deploy
# 自定义域名（有 CDN 加速域名时才填，留空走直链）
OSS_CDN_DOMAIN=
